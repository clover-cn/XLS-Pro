# 本地 API 服务器
PORT=3100
TASK_STORAGE_DIR=.agentic-tasks
SANDBOX_TIMEOUT_MS=60000
# 索引构建超时时间(毫秒)
WORKBOOK_INDEX_TIMEOUT_MS=600000
# 缓存文件默认保留时间(毫秒)
TASK_CACHE_TTL_MS=86400000
# Open AI 兼容模型端点
OPENAI_BASE_URL=https://****/v1
OPENAI_API_KEY=***
OPENAI_MODEL=deepseek-v4-pro

# 将此设置为安装了 Pandas 和 Openpyxl 的真实 Python 可执行文件
# 示例: C:\Users\zytx\AppData\Local\Programs\Python\Python311\python.exe
PYTHON_BIN=D:\Project\Agentic-Workflow-Excel\hello-world\.venv\Scripts\python.exe
